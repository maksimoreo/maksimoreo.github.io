---
import ProjectSection from '../ProjectSection.astro'
import demoTuringMachineApp from '../../assets/demo-turing-machine-app.png'
import Csharp from '../pins/Csharp.astro'
import DotNet from '../pins/DotNet.astro'
import ExternalSite from '../ExternalSite.astro'
import { Image } from 'astro:assets'
---

<ProjectSection
  backgroundColor="gray"
  isTextLeft={true}
  titleClasses={'text-gray-200'}
  descriptionClasses={'text-gray-300'}
>
  <Image
    slot="demo"
    src={demoTuringMachineApp}
    alt="Screenshot of TuringMachineApp"
  />

  <Fragment slot="title">🤓 Turing Machine Emulator</Fragment>

  <Fragment slot="short-description"
    >A Turing Machine emulator capable of running multiple machines in parallel.</Fragment
  >

  <Fragment slot="pins">
    <Csharp />
    <DotNet size="size-5" />
    <span class="font-bold">WPF</span>
  </Fragment>

  <Fragment slot="description">
    <p>Features:</p>
    <ul>
      <li>🚦 Parallel execution of multiple Turing Machines</li>
      <li>⛔ Detailed inspection and execution controls</li>
      <li>📄 Instruction set loading from files</li>
    </ul>

    <p class="mt-6 text-justify">
      Turing Machine Emulator is an education and experimental tool for
      simulating Turing Machines. It supports parallel execution, step-by-step
      debugging, and inspection of machine states, making it useful for both
      learning and experimentation.
    </p>

    <div class="mt-6 mr-4 flex justify-between">
      <p class="italic font-light text-gray-300">2020, September</p>

      <p>
        <a
          href="https://github.com/maksimoreo/TuringMachineApp/"
          class="link-white"
          target="_blank"
        >
          GitHub <ExternalSite />
        </a>
      </p>
    </div>
  </Fragment>
</ProjectSection>
